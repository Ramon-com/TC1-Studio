<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TC1.Studio.ViewModels"
             x:Class="TC1.Studio.Views.PropertyGridView">
  <DockPanel>
    <TextBlock DockPanel.Dock="Top" Text="{Binding NodeInfo}" FontWeight="Bold" Margin="4" 
               TextWrapping="Wrap" />
    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Fields}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="vm:FieldViewModel">
            <Border Margin="2" Padding="4,2" BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto">
                <Grid.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Assign Friendly Name..." IsEnabled="{Binding CanRename}"
                              Click="OnRenameField" />
                  </ContextMenu>
                </Grid.ContextMenu>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,4,0">
                  <TextBlock Text="{Binding ResolvedName}" FontWeight="Bold" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding TypeHint}" FontSize="11" Opacity="0.5" Margin="4,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <TextBox Grid.Column="1" Text="{Binding EditValue, Mode=TwoWay}"
                         FontSize="12" VerticalAlignment="Center" />
                <Button Grid.Column="2" Content="Apply" Tag="{Binding}"
                        Click="OnApplyClick"
                        FontSize="11" Padding="4,1" Margin="4,0,0,0"
                        VerticalAlignment="Center" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>
