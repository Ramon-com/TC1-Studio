<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TC1.Studio.ViewModels"
             x:Class="TC1.Studio.Views.DiffView">
  <DockPanel>
    <TextBlock DockPanel.Dock="Top" Text="Diff Viewer" FontWeight="Bold" Margin="4" />
    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Diffs}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="vm:DiffItemViewModel">
            <Border BorderThickness="0,0,0,1" BorderBrush="#333" Padding="4">
              <Grid ColumnDefinitions="30,*">
                <TextBlock Text="{Binding Icon}" Foreground="{Binding Color}" FontWeight="Bold" />
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="{Binding Diff.ResolvedName}" FontWeight="Bold" FontSize="13" />
                  <TextBlock Text="{Binding Diff.TypeHint}" FontSize="11" Opacity="0.6" />
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <StackPanel>
                      <TextBlock Text="Original:" FontSize="11" Opacity="0.5" />
                      <TextBlock Text="{Binding Diff.OldDisplay}" />
                    </StackPanel>
                    <StackPanel>
                      <TextBlock Text="Modified:" FontSize="11" Opacity="0.5" />
                      <TextBlock Text="{Binding Diff.NewDisplay}" FontWeight="Bold" />
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</UserControl>
